<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-sidebar.bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/REPLACE/WITH/PATH/TO/obsidian-claude-sidebar/bridge/server.js</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>BRIDGE_TOKEN</key>
    <string>REPLACE_WITH_TOKEN (openssl rand -hex 24)</string>
    <key>BRIDGE_HOST</key>
    <string>0.0.0.0</string>
    <key>BRIDGE_PORT</key>
    <string>8898</string>
    <key>BRIDGE_CWD</key>
    <string>/Users/you</string>
    <!-- NOTE (macOS): launchd agents cannot access iCloud Drive, ~/Documents or
         ~/Desktop until you grant the node binary Full Disk Access in
         System Settings > Privacy & Security. Until then, point BRIDGE_CWD at
         an unprotected folder (e.g. your home directory) or sessions will hang
         silently with no output. -->
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/claude-sidebar-bridge.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/claude-sidebar-bridge.log</string>
</dict>
</plist>
